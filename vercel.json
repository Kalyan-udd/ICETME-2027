{
  "builds": [
    {
      "src": "static/**",
      "use": "@vercel/static"
    },
    {
      "src": "main.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["templates/**"]
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ]
}
